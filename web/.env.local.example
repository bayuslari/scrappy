# Supabase — use the ANON (public) key here, NOT the service role key.
# Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Access control — comma-separated list of emails allowed to use the dashboard.
# Magic-link lets anyone request a sign-in link to their OWN email, so set this
# to lock the app to just you. Leave empty to allow any signed-in user.
ALLOWED_EMAILS=you@example.com
